$group

    const metas
        await
            _ getData
                @ 'production/meta/list'
    log 'componentDidMount.metas', metas
    const options 
        [
            {
                @ name ''
                @ value ''
    foreach item in metas
        _ options.push
            {
                @ name item.owner + '/' + item.name
                @ value item.owner + '|' + item.name
    _ this.setState
        {
            @ meta_listOptions options